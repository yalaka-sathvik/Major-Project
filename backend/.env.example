# Database
MONGO_URL=mongodb://localhost:27017/clear-connect

# JWT
TOKEN_KEY=your-secret-token-key

# Google OAuth
GOOGLE_CLIENT_KEY=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# URLs (for OAuth redirects - use your deployed URLs in production)
BACKEND_URL=http://localhost:9000
FRONTEND_URL=http://localhost:5173

# Email (optional - for OTP)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# AI Summary (optional - for meeting summaries)
# OPENAI_API_KEY is required for transcription (Whisper). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
# GEMINI_API_KEY optional - for summarization when AI_SUMMARY_PROVIDER=gemini. Get at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Use "openai" or "gemini" for summarization
AI_SUMMARY_PROVIDER=gemini
